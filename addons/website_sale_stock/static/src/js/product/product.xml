<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="sale.Product"
       t-inherit-mode="extension">
        <xpath expr="//div[@name='sale_product_configurator_quantity_buttons']"
               position="attributes">
            <attribute name="t-if" add="!isOutOfStock()" separator=" &amp;&amp; "/>
        </xpath>
        <xpath expr="//div[@name='sale_product_configurator_quantity_buttons']" position="after">
            <t t-call="website_sale_stock.out_of_stock"/>
        </xpath>
        <xpath expr="//button[@name='sale_product_configurator_add_button']" position="attributes">
            <attribute name="t-if" add="!isOutOfStock()" separator=" &amp;&amp; "/>
        </xpath>
        <xpath expr="//button[@name='sale_product_configurator_add_button']" position="after">
            <t t-call="website_sale_stock.out_of_stock"/>
        </xpath>
    </t>

    <t t-name="website_sale_stock.out_of_stock">
        <div t-if="isOutOfStock()"
             class="text-danger fw-bold">
            <i class="fa fa-times me-1"/>
            Out of stock
        </div>
    </t>
</templates>
