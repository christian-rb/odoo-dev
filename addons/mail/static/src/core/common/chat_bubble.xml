<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mail.ChatBubble">
        <Dropdown state="preview" position="'left-middle'" menuClass="'bg-view border-0 p-0 m-0 overflow-visible rounded-3'" manual="true" arrow="true">
            <button class="position-relative o-mail-ChatBubble" t-att-name="thread.displayName" t-on-click="() => this.thread.openChatWindow()" t-ref="root">
                <div t-if="thread.importantCounter > 0" class="o-mail-ChatBubble-counter position-absolute badge rounded-pill fw-bold o-discuss-badge">
                    <t t-out="thread.importantCounter"/>
                </div>
                <button class="o-mail-ChatBubble-close position-absolute border-0 shadow rounded-pill fw-bold fa fa-close bg-view" t-on-click.stop="() => this.props.chatWindow.close()"/>
                <ImStatus t-if="thread.correspondent and thread.correspondent.im_status != 'offline'" className="'o-mail-ChatBubble-status position-absolute'" persona="thread.correspondent" thread="thread"/>
                <button class="btn o-mail-ChatBubbleContainer-btn">
                    <img class="o-mail-ChatBubble-avatar rounded-circle shadow" t-att-src="thread.avatarUrl" alt="Thread image"/>
                </button>
            </button>
            <t t-set-slot="content">
                <div class="o-mail-ChatBubblePreview px-0 py-1" t-ref="preview">
                    <div class="text-truncate fw-bold mb-0 mx-2" t-esc="thread.displayName"/>
                    <div t-if="previewContent" class="text-truncate small mx-2 text-muted">
                        <t t-call="mail.message_preview_prefix">
                            <t t-set="message" t-value="thread.newestPersistentNotEmptyOfAllMessage"/>
                        </t>
                        <t t-esc="thread.newestPersistentNotEmptyOfAllMessage.inlineBody"/>
                    </div>
                </div>
            </t>
        </Dropdown>
    </t>
</templates>
