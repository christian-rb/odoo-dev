<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="mail.ChatWindowContainer">
    <div class="o-mail-ChatWindowContainer" t-if="(!store.discuss.isActive or ui.isSmall) and !store.chatBubbleCompact">
        <div t-if="store.hiddenChatWindows.length > 0 and !ui.isSmall" t-ref="hiddenMenu" class="o-mail-ChatWindow-hiddenMenuContainer position-fixed bottom-0">
            <t t-call="mail.ChatWindowHiddenMenu"/>
        </div>
        <t t-foreach="store.visibleChatWindows" t-as="chatWindow" t-key="chatWindow.thread?.localId">
            <ChatWindow chatWindow="chatWindow" right="store.CHAT_BUBBLE_CONTAINER_WIDTH + store.CHAT_BUBBLE_CONTAINER_MARGIN*2 + chatWindow_index * (store.CHAT_WINDOW_WIDTH + store.CHAT_WINDOW_INBETWEEN_WIDTH * 2)"/>
        </t>
    </div>
    <div t-if="!store.discuss.isActive" class="o-mail-ChatBubbleContainer position-absolute bottom-0 end-0 d-flex flex-column align-content-start justify-content-end align-items-center" t-ref="bubble-container">
        <div class="d-flex flex-column align-content-start justify-content-end align-items-center">
            <t t-if="store.chatBubbleCompact">
                <!-- In dropdown to keep same layout as other items-->
                <Dropdown>
                    <div class="o-mail-ChatBubble o-mail-ChatBubbleContainer-btn justify-content-center">
                        <button class="o-mail-ChatBubbleContainer-btn btn border-0" t-on-click="showBubbles">
                            <i class="o-mail-ChatBubbleHidden-btn d-flex justify-content-center align-items-center btn rounded-circle shadow fa fa-commenting"/>
                        </button>
                    </div>
                </Dropdown>
            </t>
            <t t-else="">
                <Dropdown state="options" position="'top-end'" menuClass="'o-mail-ChatBubbleOptions d-flex flex-column bg-view border-0 shadow m-0 p-0 mb-1'">
                    <button class="btn o-mail-ChatBubbleContainer-btn o-mail-ChatBubbleOptions-btn rounded-circle shadow fa fa-ellipsis-h bg-view mt-1" t-att-class="{ 'opacity-0': !visible.length or !bubbleContainerHover.isHover and !options.isOpen }"/>
                    <t t-set-slot="content">
                        <button t-on-click="closeBubbles" class="o-mail-ChatBubbleOptions-item btn border-0 d-flex align-items-center justify-content-start gap-2 rounded-0"><i class="fa fa-fw fa-close"></i>Close all conversations</button>
                        <button t-on-click="hideBubbles" class="o-mail-ChatBubbleOptions-item btn border-0 d-flex align-items-center justify-content-start gap-2 rounded-0"><i class="fa fa-fw fa-eye-slash"></i>Hide all conversations</button>
                    </t>
                </Dropdown>
                <t t-foreach="visible" t-as="bubble" t-key="bubble.localId">
                    <ChatBubble t-if="bubble.thread" bubble="bubble"/>
                </t>
                <Dropdown t-if="hidden.length > 0 or store.chatBubbleCompact" state="more" position="'left-middle'" menuClass="'bg-view border-0 shadow p-0 m-0 rounded-3 overflow-visible'" manual="true" arrow="true">
                    <div class="o-mail-ChatBubble o-mail-ChatBubbleContainer-btn justify-content-center" t-on-click="() => store.chatBubbleCompact = true" t-ref="more-button">
                        <button class="o-mail-ChatBubbleContainer-btn btn outline-0 border-0">
                            <i class="o-mail-ChatBubbleHidden-btn d-flex justify-content-center align-items-center btn rounded-circle shadow" t-att-class="{ 'o-active': more.isOpen }">+<t t-esc="hidden.length"/></i>
                        </button>
                    </div>
                    <t t-set-slot="content">
                        <ul class="m-0 p-0 overflow-auto" role="menu" t-ref="more-menu">
                            <t t-foreach="hidden" t-as="bubble" t-key="bubble.localId">
                                <li t-on-click="() => bubble.thread.openChatWindow()" class="o-mail-ChatBubbleHidden-item gap-2 px-2 py-1"  role="menuitem" t-att-name="bubble.thread.displayName">
                                    <img class="o-mail-ChatBubbleHidden-avatar rounded-circle" t-att-src="bubble.thread.avatarUrl" alt="Thread image"/>
                                    <p class="text-truncate fw-bold mb-0"><t t-esc="bubble.thread.displayName"/></p>
                                    <button class="o-mail-ChatBubbleHidden-close o-mail-ChatBubble-close rounded-circle" t-on-click.stop="() => bubble.close()">
                                        <i class="fa fa-fw fa-close"/>
                                    </button>
                                    <div t-if="bubble.thread.importantCounter > 0" class="o-mail-ChatBubbleHidden-counter position-absolute badge rounded-pill fw-bold o-discuss-badge">
                                        <t t-out="bubble.thread.importantCounter"/>
                                    </div>
                                </li>
                            </t>
                        </ul>
                    </t>
                </Dropdown>
            </t>
        </div>
    </div>
</t>

<t t-name="mail.ChatWindowHiddenMenu">
    <Dropdown position="'top-end'" menuClass="'o-mail-ChatWindowHiddenMenu p-0'">
        <button class="o-mail-ChatWindowHiddenToggler btn d-flex align-items-center rounded-top-3 bg-900">
            <div class="me-1 fa fa-comments-o"/>
            <div class="mx-1 text-truncate" t-esc="store.hiddenChatWindows.length"/>
            <div t-if="unread > 0" class="o-mail-ChatWindowHiddenMenu-unreadCounter position-absolute end-0 top-0 badge rounded-pill text-bg-primary" t-esc="unread"/>
        </button>
        <t t-set-slot="content">
            <ul class="m-0 p-0 overflow-auto" role="menu" t-ref="list">
                <li t-foreach="[...store.hiddenChatWindows].reverse()" t-as="chatWindow" t-key="chatWindow.thread?.localId" class="o-mail-ChatWindowHiddenMenu-item dropdown-item p-0" t-att-class="{ 'border-bottom' : !chatWindow_last }" role="menuitem">
                    <ChatWindow chatWindow="chatWindow"/>
                </li>
            </ul>
        </t>
    </Dropdown>
</t>

</templates>
