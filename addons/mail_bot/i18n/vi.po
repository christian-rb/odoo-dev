#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "Aaaaaw that's really cute but, you know, bots don't work that way. You're too human for me! Let's keep it professional ❤️"
msgstr "Aaaaaw thật dễ thương nhưng, bạn biết đấy, bot không hoạt động theo cách đó. Bạn quá con người đối với tôi! Hãy giữ cho nó chuyên nghiệp"

#. module: mail_bot
#: model:ir.model.fields.selection,name:mail_bot.selection__res_users__odoobot_state__disabled
msgid "Disabled"
