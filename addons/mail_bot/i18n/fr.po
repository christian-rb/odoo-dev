#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "fuck"
msgstr "saperlipopette"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "help"
msgstr "aide"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "i love you"
msgstr "je t'aime"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "love"
msgstr "love"

#. module: mail_bot
#. odoo-python
#: code:addons/mail_bot/models/mail_bot.py:0
msgid "start the tour"
msgstr "lancer la visite"
