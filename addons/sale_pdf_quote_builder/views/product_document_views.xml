<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="product_document_form" model="ir.ui.view">
        <field name="name">product.document.form.sale</field>
        <field name="model">product.document</field>
        <field name="inherit_id" ref="product.product_document_form"/>
        <field name="arch" type="xml">
            <field name="datas" position="after">
                <field name="has_restricted_form_fields"/>
                <button name="action_open_whitelisting_wizard" type="object"
                        string="Allow new fields"
                        help="Mark fields as safe to fill in the document."
                        class="btn-link" icon="fa-refresh"
                        groups="base.group_system"
                        invisible="not has_restricted_form_fields"/>
            </field>
        </field>
    </record>

</odoo>
