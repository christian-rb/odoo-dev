<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="form_field_whitelist_list" model="ir.ui.view">
        <field name="model">pdf.quote.builder.form.field.whitelist</field>
        <field name="arch" type="xml">
            <tree string="Whitelist" editable="top" create="1" delete="1">
                <field name="res_name"/>
                <field name="res_model"/>
                <field name="res_field"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </tree>
        </field>
    </record>

<!--    TODO edm: fieldS?-->
    <record id="action_form_field_whitelist" model="ir.actions.act_window">
        <field name="name">PDF Quote Builder Form Fields Whitelist</field>
        <field name="res_model">pdf.quote.builder.form.field.whitelist</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_neutral_face">
                There are no whitelisted field yet
            </p>
        </field>
    </record>

    <menuitem action="action_form_field_whitelist" id="menu_action_form_field_whitelist" name="Quote Builder Form Fields Whitelist" parent="sale.menu_sales_config"/>

</odoo>
