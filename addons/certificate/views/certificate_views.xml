<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    <record id="certificate_form_view" model="ir.ui.view">
        <field name="name">certificate.form</field>
        <field name="model">certificate.certificate</field>
        <field name="arch" type="xml">
            <form string="certificate form">
                <sheet>
                    <group id='certificate_input'>
                        <field name="name"/>
                        <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                        <field name="content" widget="binary"/>
                        <field name="content_format" widget="radio"/>
                        <field name="private_key" invisible="content_format == 'pkcs12'"/>
                        <field name="private_key_format" widget="radio" invisible="content_format == 'pkcs12'"/>
                        <field name="private_key_password" password="True" invisible="content_format == 'pkcs12'"/>
                        <field name="pkcs12_password" password="True" invisible="content_format != 'pkcs12'"/>
                        <field name="hashing_algorithm"/>
                    </group>    
                    <group id='certificate_data'>
                        <label for="date_start" string="Validity"/>
                        <div>
                            <field name="date_start" interval="year" widget="remaining_days" class="oe_inline"/> - <field name="date_end" widget="remaining_days" class="oe_inline"/>
                        </div>
                        <field name="serial_number"/>
                        <field name="pem_certificate" invisible="content_format == 'pem'" widget="binary"/>
                        <field name="pem_private_key" invisible="private_key_format == 'pem'" widget="binary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="certificate_list_view" model="ir.ui.view">
        <field name="name">certificate.list</field>
        <field name="model">certificate.certificate</field>
        <field name="arch" type="xml">
            <tree string="certificate list">
                <field name="name"/>
                <field name="is_valid" string="Validity"/>
                <field name="company_id" groups="base.group_multi_company" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="certificate_search_view" model="ir.ui.view">
        <field name="name">certificate.search</field>
        <field name="model">certificate.certificate</field>
        <field name="arch" type="xml">
            <search string="certificate search">
                <filter string="Not valid" name="not_valid" domain="[('is_valid','=',False)]" help = "Not valid certificates"/>
                <filter string="Valid" name="valid" domain="[('is_valid','=',True)]" help = "Valid certificates"/>
                <separator/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]" help = "Archived certificates"/>
            </search>
        </field>
    </record>
</odoo>
