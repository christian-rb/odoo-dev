<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_company_form_inherit_l10n_ke_edi_oscu" model="ir.ui.view">
            <field name="name">res.company.form.inherit</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <page name="general_info" position="after">
                    <page string="eTIMS" name="l10n_ke_edi_oscu_details" >
                        <field name="l10n_ke_oscu_cmc_key" invisible="1"/>
                        <group>
                            <group string="OSCU Details">
                                <field name="l10n_ke_oscu_branch_code"/>
                                <field name="l10n_ke_oscu_serial_number"/>
                                <field name="l10n_ke_control_unit" readonly="1"/>
                                <field name="l10n_ke_oscu_cmc_key" password="True" groups="base.group_no_one"/>
                                <field name="l10n_ke_server_mode" groups="base.group_no_one"/>
                                <button name="action_l10n_ke_oscu_initialize" string="Initialize OSCU" type="object" invisible="l10n_ke_oscu_cmc_key"/>
                            </group>
                            <group string="Insurance">
                                <field name="l10n_ke_insurance_code"/>
                                <field name="l10n_ke_insurance_name"/>
                                <field name="l10n_ke_insurance_rate"/>
                                 <div class="cell"/>
                                <button name="action_l10n_ke_send_insurance" string="Send Insurance Details" type="object"/>
                            </group>
                            <group string="Actions" groups="base.group_no_one">
                                <div class="cell"/>
                                <button name="action_l10n_ke_get_item_codes" string="Get Item Codes" type="object"/>
                                <div class="cell"/>
                                <button name="action_l10n_ke_get_stock_moves" string="Get Stock Moves List" type="object"/>
                            </group>
                        </group>
                    </page>
                </page>
                <field name="child_ids" position="before">
                    <div class="text-muted" colspan="2" invisible="country_code != 'KE' or l10n_ke_oscu_branch_code != '00'">
                        Information about branches on this company can be fetched from the KRA and used to create branches in Odoo.
                        The OSCU will need to be initialized independently for each of these branches.
                        <button class="p-0 border-0 oe_inline oe_link" icon="fa-arrow-right" name="action_l10n_ke_create_branches" string="Populate from KRA" type="object"/>
                    </div>
                </field>
            </field>
        </record>
    </data>
</odoo>
