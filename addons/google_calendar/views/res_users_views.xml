<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_users_form" model="ir.ui.view">
            <field name="name">res.users.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="calendar.res_users_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='calendar']" position='attributes'>
                    <attribute name="invisible">0</attribute>
                </xpath>
                <group name="calendar_accounts" position="inside">
                    <group string="Google Calendar">
                        <group class="text-break">
                            <field name="google_calendar_rtoken" readonly="1" groups="base.group_system"/>
                            <field name="google_calendar_token" readonly="1"/>
                            <field name="google_calendar_token_validity" readonly="1"/>
                            <field name="google_calendar_sync_token" readonly="1"/>
                            <field name="google_calendar_cal_id" readonly="1"/>
                            <button
                                string="Reset Account" colspan="2" class="btn btn-secondary mt-3"
                                type="action" name="%(google_calendar_reset_account_action)d"
                                context="{'default_user_id': id}"/>
                        </group>
                    </group>
                </group>
            </field>
        </record>

    <record id="view_calendar" model="ir.ui.view">
        <field name="name">res.users.preferences.form.calendar</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <!-- Set the Integrations group in calendar module as visible. -->
            <xpath expr="//page[@name='calendar']//group[@name='integrations']" position='attributes'>
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//page[@name='calendar']" position='inside'>
                <!-- Google synchronization unpause/stop/refresh buttons. -->
                <button name="action_google_unpause_sync" type="object" class="btn btn-warning text-nowrap m-1"
                    invisible="google_sync_status in ('missing_credentials', 'sync_stopped', 'sync_active')">
                        <b>
                            <i title="Pause" class='fa fa-pause'/>
                            <span class="mx-1">Google</span>
                        </b>
                </button>
                <button name="action_google_refresh_sync" type="object" class="btn btn-secondary text-nowrap m-1"
                    invisible="google_sync_status in ('missing_credentials', 'sync_paused', 'sync_active')">
                        <b>
                            <i title="Refresh" class='fa fa-refresh'/>
                            <span class="mx-1">Google</span>
                        </b>
                </button>
                <button name="action_google_stop_sync" type="object" class="btn btn-outline-primary text-nowrap m-1"
                    invisible="google_sync_status in ('missing_credentials', 'sync_stopped', 'sync_paused')">
                    <b>
                        <i title="Check" class='fa fa-check fa-fw'/>
                        <i title="Stop" class='fa fa-times fa-fw'/>
                        <span class="mx-1">Google</span>
                    </b>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
