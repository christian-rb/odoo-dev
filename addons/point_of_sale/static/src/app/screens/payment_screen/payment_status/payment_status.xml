<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="point_of_sale.PaymentScreenStatus">
        <t t-if="props.order.get_paymentlines().length !== 0">
            <section class="paymentlines-container p-3 mb-1 border-bottom">
                <div class="payment-status-container d-flex flex-column-reverse flex-lg-row justify-content-between fs-2">
                    <t t-if="this.props.order.get_due() >= 0 and props.order.get_change() === 0">
                        <div class="payment-status-remaining d-flex justify-content-between flex-grow-1">
                            <span class="label pe-2">Remaining</span>
                            <span class="amount align-self-end" t-att-class="{ 'highlight text-primary fw-bolder': props.order.get_due() > 0 }">
                                <t t-esc="remainingText" />
                            </span>
                        </div>
                    </t>
                    <t t-else="">
                        <div class="payment-status-change d-flex justify-content-between flex-grow-1">
                            <span class="label pe-2">Change</span>
                            <span class="amount" t-att-class="{ 'highlight text-primary fw-bolder': props.order.get_change() > 0 }">
                                <t t-esc="changeText" />
                            </span>
                        </div>
                    </t>
                </div>
            </section>
        </t>
    </t>
</templates>
