<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <t t-name="point_of_sale.PosKanbanRenderer" t-inherit="web.KanbanRenderer" t-inherit-mode="primary">
        <t t-call="web.ActionHelper" position="replace">
            <t t-if="!hasPosConfig">
                <PosActionHelper noContentHelp="props.noContentHelp" hasChartTemplate="hasChartTemplate" />
            </t>
        </t>
    </t>

    <t t-name="point_of_sale.PosActionHelper">
        <div class="container">
            <div class="flex-grow-1 text-center mt-5">
                <t t-if="loadScenario.status !== 'loading' || loadConfig.status !== 'loading'">
                    <t t-if="!state.haveAvailableProducts">
                        <p t-if="!props.hasChartTemplate" class="h1 text-primary">
                            Please install a chart template for this company to install demo scenarios
                        </p>
                        <t t-else="">
                            <p class="h1 text-primary">No products defined yet !</p>
                            <p class="h2 m-3">Do you want to try our sample data ?</p>
                            <div class="shop-scenarios row p-3">
                                <t t-foreach="shopScenarios" t-as="item" t-key="item_index">
                                    <div class="col-md-4">
                                        <div class="card mb-3 rounded-3 scenario-card" style="max-width: 540px;" t-on-click="() => this.loadScenario.call(item.function_name)">
                                            <div class="row g-0">
                                                <div class="col-md-4">
                                                    <div class="img-container m-2 d-flex align-items-center justify-content-center">
                                                        <img t-attf-src="/point_of_sale/static/src/img/{{item.icon_file}}" class="scenario-img"/>
                                                    </div>
                                                </div>
                                                <div class="col-md-8">
                                                    <div class="card-body text-start p-3 m-2">
                                                        <h3 class="card-title fw-bolder" t-esc="item.name"/>
                                                        <p class="card-text text-large" t-esc="item.description"/>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="text-center my-4">
                                <div class="row">
                                    <div class="col">
                                        <hr class="my-2"/>
                                    </div>
                                    <div class="col-auto">
                                        <span class="px-3 h4">or</span>
                                    </div>
                                    <div class="col">
                                        <hr class="my-2"/>
                                    </div>
                                </div>
                            </div>
                            <p class="text-large"><a role="button" class="btn btn-secondary fw-bolder" t-on-click="createNewProducts">Create my own products</a></p>
                        </t>
                    </t>
                    <t t-else="">
                        <p class="h1 m-4">Create your first point of sale</p>
                        <div class="row p-3 m-4 justify-content-center">
                            <t t-foreach="predefinedConfigs" t-as="item" t-key="item_index">
                                <div class="col-md-4">
                                    <div class="card mb-3 rounded-3 scenario-card" style="max-width: 540px;" t-on-click="() => this.loadConfig.call(item.function_name)">
                                        <div class="row g-0">
                                            <div class="col-md-4">
                                                <div class="img-container m-2 d-flex align-items-center justify-content-center">
                                                    <img t-attf-src="{{item.icon_file}}" class="scenario-img"/>
                                                </div>
                                            </div>
                                            <div class="col-md-8">
                                                <div class="card-body text-start p-3 m-2">
                                                    <h3 class="card-title fw-bolder" t-esc="item.name"/>
                                                    <p class="card-text text-large" t-esc="item.description"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </t>
                <div t-else="" class="block-top-header position-absolute top-0 start-0 bg-black opacity-50 w-100 h-100 z-1000">
                    <div class="d-flex h-100 w-100 text-white flex-row align-items-center justify-content-center">
                        <div class="o_spinner d-flex flex-column mb-4">
                            <img src="/web/static/img/spin.svg" alt="Loading..."/>
                            Loading...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</odoo>
