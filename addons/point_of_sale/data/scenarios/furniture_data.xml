        <function model="ir.model.data" name="_update_xmlids">
            <value model="base" eval="[{
                        'xml_id': 'point_of_sale.desk_organizer_product_template',
                        'record': obj().env.ref('point_of_sale.desk_organizer').product_tmpl_id,
                        'noupdate': True,
                    }]" />
