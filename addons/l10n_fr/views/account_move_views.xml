<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_form_l10n_fr" model="ir.ui.view">
        <field name="name">l10n_fr.account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="(//group[@id='header_left_group']/*)[last()]" position="after">
                <field name="invoice_partner_id" attrs="{'invisible': [('country_code','!=', 'FR')]}"/>
                <field name="delivery_partner_id" attrs="{'invisible': [('country_code','!=', 'FR')]}"/>
            </xpath>
        </field>
    </record>
</odoo>
