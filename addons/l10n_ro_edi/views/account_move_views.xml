<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="l10n_ro_edi_view_move_form" model="ir.ui.view">
        <field name="name">l10n_ro_edi.view.move.form</field>
        <field name="model">account.move</field>
        <field name="priority">30</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='journal_div']" position="after">
                <label for="l10n_ro_edi_state"
                       invisible="not l10n_ro_edi_state or state == 'draft' or move_type in ('in_invoice', 'in_refund')"/>
                <div name="l10n_ro_edi_div"
                     class="d-flex"
                     invisible="not l10n_ro_edi_state or state == 'draft' or move_type in ('in_invoice', 'in_refund')">
                    <field name="l10n_ro_edi_state" class="oe_inline"/>
                </div>
            </xpath>

            <!-- CIUS-RO Documents Tab -->
            <xpath expr="//page[@id='other_tab_entry']" position="after">
                <page id="l10n_ro_edi_documents"
                      string="E-Factura"
                      invisible="not l10n_ro_edi_document_ids">
                    <field name="l10n_ro_edi_document_ids">
                        <tree create="false" edit="false"
                              decoration-primary="state == False"
                              decoration-danger="state == 'error'"
                              decoration-warning="state in ('sending', 'nok')"
                              decoration-success="state in ('sent', 'ok')">
                            <field name="datetime"/>
                            <field name="state"/>
                            <button name="action_l10n_ro_edi_fetch_status"
                                    type="object"
                                    string="Fetch status"
                                    invisible="state != 'sending'"/>
                            <button name="action_l10n_ro_edi_download_answer"
                                    type="object"
                                    string="Download answer"
                                    invisible="state not in ('ok', 'nok')"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="l10n_ro_edi_view_out_invoice_tree_inherit" model="ir.ui.view">
        <field name="name">account.out.invoice.tree.inherit.l10n.ro.edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="l10n_ro_edi_state" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="l10n_ro_edi_view_out_credit_note_tree_inherit" model="ir.ui.view">
        <field name="name">account.out.credit.note.tree.inherit.l10n.ro.edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_credit_note_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="l10n_ro_edi_state" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="l10n_ro_edi_view_in_invoice_bill_tree_inherit" model="ir.ui.view">
        <field name="name">account.in.invoice.tree.inherit.l10n.ro.edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="l10n_ro_edi_state" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="l10n_ro_edi_view_account_invoice_filter" model="ir.ui.view">
        <field name="name">account.invoice.select.inherit.l10n.ro.edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='journal_id']" position="after">
                <field name="l10n_ro_edi_state"/>
            </xpath>
            <xpath expr="//filter[@name='to_check']" position="after">
                <filter string="Sending to E-Factura" name="l10n_ro_edi_state_sending"
                        domain="[('l10n_ro_edi_state', '=', 'sending')]"/>
                <filter string="Error from E-Factura" name="l10n_ro_edi_state_error"
                        domain="[('l10n_ro_edi_state', 'in', ('nok', 'error'))]"/>
                <filter string="Processed by E-Factura" name="l10n_ro_edi_state_processed"
                        domain="[('l10n_ro_edi_state', 'in', ('ok', 'sent'))]"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="E-Factura Status" name="l10n_ro_edi_state_group"
                        domain="" context="{'group_by':'l10n_ro_edi_state'}"/>
            </xpath>
        </field>
    </record>

    <record id="l10n_ro_edi_action_fetch_ciusro_status" model="ir.actions.server">
        <field name="name">Fetch E-Factura Status</field>
        <field name="model_id" ref="account.model_account_move"/>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            if records:
                records._l10n_ro_edi_fetch_batch_status()
        </field>
    </record>

</odoo>
