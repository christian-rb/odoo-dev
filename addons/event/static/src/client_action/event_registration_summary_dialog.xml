<?xml version="1.0" encoding="utf-8"?>

<templates xml:space="preserve">

    <t t-name="event.EventRegistrationSummaryDialog" >
       <Dialog size="'md'" title="'Home'">
            <div class="row">
                <div class="col-lg-10 w-100 fs-2">
                    <div t-if="registration_status.value === 'confirmed_registration'" class="alert alert-success text-center" role="alert">
                        <i class="fa fa-solid fa-check-circle"/><br/>
                        <span>Successfully registered!</span>
                    </div>
                    <div t-else="" class="alert alert-warning text-center" role="alert">
                        <i class="fa fa-solid fa-exclamation-circle"/><br/>
                        <t t-if="registration_status.value === 'need_manual_confirmation'">
                            <span>This ticket is for another event<br/>
                            Confirm attendance for <t t-out="registration.name"/>?</span>
                        </t>
                        <t t-elif="registration_status.value === 'not_ongoing_event'">
                            <span>This ticket is not for an ongoing event</span>
                        </t>
                        <t t-elif="registration_status.value === 'canceled_registration'">
                            <span>Cancelled registration</span>
                        </t>
                        <t t-elif="registration_status.value == 'already_registered'">
                            <span>Ticket already scanned!</span>
                        </t>
                    </div>
                </div>
            </div>
            <div class="row fs-1">
                <div class="col-lg-12 d-flex-inline">
                    <t t-if="registration.name" t-out="registration.name"/>
                    <t t-else="" t-out="'Guest #' + registration.id"/>
                    <t t-if="registration.sale_status_value">
                        <span> : </span>
                        <span class="badge rounded-pill" t-att-class="registration.has_to_pay ? 'text-bg-danger' : 'text-bg-success'">
                            <t t-out="registration.sale_status_value"/>
                        </span>
                    </t>
                </div>
            </div>
            <div id="registration_information" class="row mt-4">
                <div class="col-lg-12">
                    <table class="table table-striped fs-4">
                        <tr t-if="registration.company_name"><td>Company</td><td><t t-out="registration.company_name"/></td></tr>
                        <tr><td>Event</td><td><t t-out="registration.event_display_name"/></td></tr>
                        <tr t-if="registration.ticket_name"><td>Ticket Type</td><td><t t-out="registration.ticket_name"/></td></tr>
                        <t t-if="registration.registration_questions_answers">
                            <tr t-if="registration.registration_questions_answers.length > 0">
                                <td class="d-flex">Answers</td>
                                <td>
                                    <div class="d-flex flex-column align-items-start p-0">
                                        <span t-foreach="registration.registration_questions_answers" t-as="registration_questions_answers" t-key="registration_questions_answers_index"
                                        t-attf-class="o_tag o_tag_badge_text o_tag_color_#{registration_questions_answers_index % 10} badge rounded-pill p-1 me-1 mb-1"
                                        t-out="registration_questions_answers.question + ' ' + registration_questions_answers.answers.join(', ')"/>
                                    </div>
                                </td>
                            </tr>
                        </t>
                    </table>
                </div>
            </div>
            <div class="row mt-4 fs-2">
                <div class="col-lg-12" t-on-click="() => this.onRegistrationPrintPdf()">
                    <i class="fa fa-solid fa-print"/><i class="fa fa-solid fa-circle-exclamation"/><span class="link-success"> Print Ticket</span>
                </div>
            </div>
            <div class="row fs-2">
                <div class="col-lg-12" t-on-click="() => this.onRegistrationView()">
                    <i class="fa fa-regular fa-file"/><span class="link-success"> Open Details</span>
                </div>
            </div>
            <t t-set-slot="footer">
                <button t-if="registration_status.value === 'need_manual_confirmation'" class="btn btn-primary" t-on-click="() => this.onRegistrationConfirm()">Confirm</button>
                <button t-elif="isBarcodeScannerSupported" class="btn btn-primary" t-on-click="() => this.onScanNext()">Scan Next</button>
                <button class="btn btn-secondary" t-on-click="() => this.props.close()">Close</button>
            </t>
        </Dialog>
    </t>

</templates>
