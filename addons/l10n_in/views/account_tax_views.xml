<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tax_form_inherit_l10n_in" model="ir.ui.view">
        <field name="name">account.tax.form.inherit.l10n.in</field>
        <field name="model">account.tax</field>
        <field name="inherit_id" ref="account.view_tax_form"/>
        <field name="arch" type="xml">
            <field name="is_base_affected" position="after">
                <field name="l10n_in_reverse_charge" invisible="amount_type == 'group' or country_code != 'IN'"/>
            </field>
        </field>
    </record>

    <record id="view_tax_group_form_inherit" model="ir.ui.view">
        <field name="name">tax.group.form.view.inherit</field>
        <field name="model">account.tax.group</field>
        <field name="inherit_id" ref="account.view_tax_group_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sequence']" position="after">
                <field name="l10_in_is_threshold" widget="boolean_toggle" invisible="country_code != 'IN'"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <group name="tds_threshold_limit" string="TDS Threshold Limit" invisible="l10_in_is_threshold == False or country_code != 'IN'">
                    <field name="l10n_in_consider_tax" invisible="l10_in_is_threshold == False"/>
                    <label for="l10n_in_is_per_transection_limit"/>
                    <div class="per-transection d-flex">
                        <field class=" w-25 inline-block" name="l10n_in_is_per_transection_limit" widget="boolean_toggle"/>
                        <field class="inline-block" name="l10n_in_per_transection_limit" invisible="l10_in_is_threshold == False or l10n_in_is_per_transection_limit == False"/>
                    </div>
                    <label for="l10n_in_is_aggregate_limit"/>
                    <div class="aggregate d-flex">
                        <field class="w-25 inline-block" name="l10n_in_is_aggregate_limit" widget="boolean_toggle"/>
                        <field class="inline-block" name="l10n_in_aggregate_limit" invisible="l10_in_is_threshold == False or l10n_in_is_aggregate_limit == False"/>
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
