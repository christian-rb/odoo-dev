<templates id="template" xml:space="preserve">
    <t t-name="pos_loyalty.ManageGiftCardPopup">
        <Dialog title="props.title" size="'md'">
            <t t-foreach="props.buttons" t-as="button" t-key="button_index">
                <button t-on-click="() => this.buttonClick(button)" type="button" t-attf-class="btn me-2 mb-2 toggle-button {{button.isSelected? 'btn-primary' : 'btn-secondary'}}">
                    <t t-esc="button.label"/>
                </button>
            </t>
            <input t-att-rows="props.rows" class="form-control form-control-lg mx-auto" type="text" t-model="state.inputValue" t-ref="input" t-att-placeholder="props.placeholder" t-att-style="state.error ? 'border-color: red;' : ''" />
            <div class="error-message" t-if="state.error" t-esc="state.error"/>
            <div class="mt-3">
                <div class="col align-items-center d-flex">
                    <div class="col-form-label text-center pe-0 me-3 fs-5">Amount</div>
                    <div class="flex-grow-1">
                        <input id="amount" class="form-control form-control-lg" type="number" step="0.01" t-model="state.amountValue" t-ref="amountInput" placeholder="Enter amount" t-att-style="state.amountError ? 'border-color: red;' : ''"/>
                        <div class="error-message" t-if="state.amountError" t-esc="state.amountError"/>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary o-default-button" t-on-click="confirm">Add Balance</button>
            </t>
        </Dialog>
    </t>
</templates>
