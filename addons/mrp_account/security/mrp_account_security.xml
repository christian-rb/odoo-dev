<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">

    <record id="analytic_line_rule_mrp_user_update-unlink" model="ir.rule">
        <field name="name">account.analytic.line.mrp.user.update-unlink</field>
        <field name="model_id" ref="analytic.model_account_analytic_line"/>
        <field name="domain_force">[
            ('user_id', '=', user.id),
            ('category', '=', 'manufacturing_order')
        ]</field>
        <field name="groups" eval="[(4, ref('mrp.group_mrp_user'))]"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="perm_read" eval="0"/>
    </record>

</odoo>
