<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_template_form_view_inherit_account_l10n_ke_edi_oscu" model="ir.ui.view">
            <field name="name">product.template.form.inherit.account.l10n.ke.edi.oscu</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="account.product_template_form_view"/>
            <field name="arch" type="xml">
                <button name="action_l10n_ke_oscu_save_item" position="after">
                    <div class="cell"/>
                    <button name="action_l10n_ke_oscu_save_stock_master" string="Save Stock Master"
                            type="object" groups="base.group_no_one"/>
                    <div class="cell"/>
                </button>
            </field>
        </record>
        <record id="product_product_form__view_inherit_l10n_ke_edi_oscu" model="ir.ui.view">
            <field name="name">product.product.form.inherit.l10n.ke.edi.oscu</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
            <field name="arch" type="xml">
                <button name="action_l10n_ke_oscu_save_item" position="after">
                    <div class="cell"/>
                    <button name="action_l10n_ke_oscu_save_stock_master" string="Save Stock Master" type="object"/>
                </button>
            </field>
        </record>


        <record id="account.product_product_action_sellable" model="ir.actions.act_window">
            <field name="context">{'search_default_filter_to_sell': 1, 'default_detailed_type': 'product'}</field>
        </record>

        <record id="account.product_product_action_purchasable" model="ir.actions.act_window">
            <field name="context">{'search_default_filter_to_purchase': 1, 'default_detailed_type': 'product'}</field>
        </record>


        <record id="sale.product_template_action" model="ir.actions.act_window">
            <field name="context">{"search_default_filter_to_sell":1, "sale_multi_pricelist_product_template": 1, 'default_detailed_type': 'product'}</field>
        </record>

        <record id="purchase.product_normal_action_puchased" model="ir.actions.act_window">
            <field name="context">{"search_default_filter_to_purchase":1, "purchase_product_template": 1, 'default_detailed_type': 'product'}</field>
        </record>

        <record id="purchase.product_product_action" model="ir.actions.act_window">
            <field name="context">{"search_default_filter_to_purchase": 1, 'default_detailed_type': 'product'}</field>
        </record>


    </data>
</odoo>
