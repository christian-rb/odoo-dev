<odoo>
    <record id="view_project_form_mrp_project" model="ir.ui.view">
        <field name="name">project.form.inherit.mrp.project</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" name="action_view_linked_mrp_productions" type="object" icon="fa-wrench" invisible="production_count_direct_link == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value"><field name="production_count_direct_link"/></span>
                        <span class="o_stat_text">Manufacturing Orders</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='date']" position="after">
                <field name="production_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>
