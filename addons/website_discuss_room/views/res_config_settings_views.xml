<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.website.discuss.room</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="event.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='events_setting_container']" position="inside">
                <setting string="Discuss Server Domain" help="Define Discuss Server domain">
                    <field name="chat_room_server_domain" placeholder="localhost:8069"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
