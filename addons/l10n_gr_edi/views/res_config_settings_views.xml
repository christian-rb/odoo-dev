<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_form_inherit_l10n_gr_reports" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.l10n.gr.reports</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="after">
                <block title="Greece MyDATA" id="l10n_gr_reports_settings" invisible="country_code != 'GR'">
                    <div class="col-12 col-lg-12 o_setting_box">
                        <div class="o_setting_right_pane border-0">
                            <div class="row">
                                <label for="l10n_gr_aade_user_id" class="col-lg-3 o_light_label"/>
                                <field name="l10n_gr_aade_user_id"/>
                            </div>
                            <div class="row">
                                <label for="l10n_gr_subscription_key" class="col-lg-3 o_light_label"/>
                                <field name="l10n_gr_subscription_key"/>
                            </div>
                        </div>
                    </div>

                    <!--Test credential fields-->
                    <div class="col-12 col-lg-12 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="l10n_gr_edi_test_env"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="l10n_gr_edi_test_env" class="col-lg-3 o_light_label"/>
                            <div class="text-muted mb-3">
                                Enable test environments with credentials obtained from
                                <code>https://mydata-dev-register.azurewebsites.net/</code>
                            </div>
                            <div class="row" invisible="not l10n_gr_edi_test_env">
                                <label for="l10n_gr_edi_test_id" class="col-lg-3 o_light_label"/>
                                <field name="l10n_gr_edi_test_id"/>
                            </div>
                            <div class="row" invisible="not l10n_gr_edi_test_env">
                                <label for="l10n_gr_edi_test_vat" class="col-lg-3 o_light_label"/>
                                <field name="l10n_gr_edi_test_vat"/>
                            </div>
                            <div class="row" invisible="not l10n_gr_edi_test_env">
                                <label for="l10n_gr_edi_test_key" class="col-lg-3 o_light_label"/>
                                <field name="l10n_gr_edi_test_key"/>
                            </div>
                        </div>
                    </div>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
