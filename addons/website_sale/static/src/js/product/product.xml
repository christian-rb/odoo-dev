<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="sale.Product"
       t-inherit-mode="extension">
        <xpath expr="//div[@name='sale_product_configurator_quantity_buttons']"
               position="attributes">
            <attribute name="t-if">this.props.can_be_sold</attribute>
        </xpath>
        <xpath expr="//div[@name='sale_product_configurator_quantity_buttons']" position="after">
            <t t-call="website_sale.not_for_sale"/>
        </xpath>
        <xpath expr="//button[@name='sale_product_configurator_add_button']" position="attributes">
            <attribute name="t-if">this.props.can_be_sold</attribute>
        </xpath>
        <xpath expr="//button[@name='sale_product_configurator_add_button']" position="after">
            <t t-call="website_sale.not_for_sale"/>
        </xpath>
        <xpath expr="//t[@name='sale_product_configurator_price']" position="before">
            <t t-call="website_sale.strikethrough_product_price"/>
        </xpath>
        <xpath expr="//t[@name='sale_product_configurator_optional_price']" position="before">
            <t t-call="website_sale.strikethrough_product_price"/>
        </xpath>
    </t>

    <t t-name="website_sale.not_for_sale">
        <div t-if="!this.props.can_be_sold"
             class="text-danger fw-bold">
            <i class="fa fa-times me-1"/>
            Not available for sale
        </div>
    </t>

    <t t-name="website_sale.strikethrough_product_price">
        <h5 class="oe_striked_price text-danger small"
            t-if="this.props.strikethrough_price"
            t-out="getFormattedStrikethroughPrice()"/>
    </t>
</templates>
