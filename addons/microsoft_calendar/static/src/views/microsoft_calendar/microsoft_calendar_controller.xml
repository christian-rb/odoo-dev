<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="microsoft_calendar.MicrosoftCalendarController" t-inherit="calendar.AttendeeCalendarController" t-inherit-mode="extension">
        <xpath expr="//div[@id='header-sync-settings']//h5[@id='synchronize_with']" position="after">
            <div id="microsoft_calendar_sync" class="o_calendar_sync mx-1 d-inline-flex" t-if="model.microsoftCredentialsSet">
                <button t-if="!model.microsoftIsSync and !model.microsoftIsPaused" type="button" id="microsoft_sync_pending" class="o_microsoft_sync_button o_microsoft_sync_pending btn btn-primary text-nowrap" t-on-click="onMicrosoftSyncCalendar">
                    <b>Outlook</b>
                </button>
            </div>
        </xpath>
    </t>
</templates>
