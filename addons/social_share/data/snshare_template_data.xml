            </div>
        </div>
    </body>
</html>
        </field>
    </record>

    <record id="snshare_template_group_1" model="snshare.template.group">
        <field name="name">Base Templates</field>
        <field name="template_ids" eval="[Command.link(snshare_template_1), Command.link(snshare_template_2)]"/>
    </record>
</data></odoo>
