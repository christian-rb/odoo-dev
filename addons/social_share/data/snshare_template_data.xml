                />
                <div class="text_section" t-if="section_1">
                    <span t-out="section_1" t-att-style="'color: {%s};' % section_1_color if section_1_color else ''"/>
                    <span t-out="subsection_1" t-att-style="'color: {%s};' % subsection_1_color if subsection_1_color else ''"/>
                </div>
                </t>
            </div>

            <div class="white rounded_button" t-if="button">
