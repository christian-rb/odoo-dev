<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_users_identitycheck_view_form_passkey" model="ir.ui.view">
        <field name="model">res.users.identitycheck</field>
        <field name="inherit_id" ref="base.res_users_identitycheck_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='password']" position="attributes">
                <attribute name="autocomplete">webauthn</attribute>
            </xpath>

            <xpath expr="//form" position="attributes">
                <attribute name="js_class">passkey_conditional_field</attribute>
            </xpath>
        </field>
    </record>
</odoo>
