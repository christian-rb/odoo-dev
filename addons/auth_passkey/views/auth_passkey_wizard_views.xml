<?xml version="1.0"?>
<odoo>
    <record id="auth_passkey_key_create" model="ir.ui.view">
        <field name="name">auth.passkey.key.create</field>
        <field name="model">auth.passkey.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
                <footer>
                    <widget name="create_passkey_button" data-hotkey="c"/>
                    <button special="cancel" data-hotkey="x" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
