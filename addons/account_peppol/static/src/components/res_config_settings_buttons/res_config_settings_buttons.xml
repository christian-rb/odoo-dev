<?xml version="1.0" encoding="UTF-8"?>

<templates>
    <t t-name="account_peppol.ActionButtons">
        <xpath expr="//div[hasclass('action_buttons')]" position="inside">
            <div class="d-flex" colspan="3">
                <div class="mt-3">
                    <button type="button"
                            class="btn btn-primary me-1"
                            t-on-click="createSender"
                            t-if="proxyState === 'not_registered'">
                            <t t-out="createButtonLabel"/>
                    </button>
                </div>
                <div class="mt-3">
                    <button type="button"
                            class="btn btn-primary me-1"
                            t-on-click="createReceiver"
                            t-if="proxyState === 'sender' and smpRegistration">
                            Register as a receiver
                    </button>
                </div>
                <div class="mt-3">
                    <button type="button"
                            class="btn btn-secondary me-1"
                            t-on-click="migrate"
                            t-if="proxyState === 'receiver' and migrationPrepared === false and ediMode != 'demo'">
                            Migrate registration to another service
                    </button>
                </div>
                <div class="mt-3">
                    <button type="button"
                            class="btn btn-primary me-1"
                            t-on-click="updateDetails"
                            t-if="['sender', 'smp_registration', 'receiver'].includes(proxyState)">
                            Update contact details
                    </button>
                </div>
                <div class="mt-3">
                    <button type="button"
                            class="btn btn-primary me-1"
                            t-on-click="checkCode"
                            t-if="proxyState === 'in_verification'">
                            Confirm
                    </button>
                </div>
                <div class="mt-3">
                    <button type="button"
                            class="btn btn-secondary me-1"
                            t-on-click="sendCode"
                            t-att-disabled="this.state.isSmsButtonDisabled"
                            t-if="proxyState === 'in_verification'">
                            Send again
                    </button>
                </div>
                <div class="mt-3">
                    <button type="button"
                            class="btn btn-secondary me-1"
                            t-on-click="deregister"
                            t-if="![false, 'not_registered'].includes(proxyState) and migrationPrepared === false">
                            <t t-out="deregisterUserButtonLabel"/>
                    </button>
                </div>
            </div>
        </xpath>
    </t>
</templates>
