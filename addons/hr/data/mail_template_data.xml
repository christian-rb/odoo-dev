<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <template id="employee_edit_notify">
            <b><t t-out="user_name"/></b> edited his own data on the <b><t t-out="current_date"/></b>
            <ul class="mb-0 ps-4">
                <li class="o-mail-Message-tracking mb-1" t-foreach="tracking_values" t-as="tracking_value">
                    <span class="o-mail-Message-trackingField ms-1"><t t-out="tracking_value.get('field_name')"/> :</span>
                    <span class="o-mail-Message-trackingOld me-1 px-1 text-muted fw-bold" t-out="tracking_value.get('old_value_char') or 'None'"/>
                    <i class="o-mail-Message-trackingSeparator fa fa-long-arrow-right mx-1 text-600"/>
                    <span class="o-mail-Message-trackingNew mx-1 fw-bold text-info" t-out="tracking_value.get('new_value_char') or 'None'"/>
                </li>
            </ul>
        </template>
    </data>
</odoo>
